# termifun fish completion
# Install: copy to ~/.config/fish/completions/termifun.fish
complete -c termifun -l help -s h -d 'Show help'
complete -c termifun -l version -s v -d 'Show version'
complete -c termifun -l list -s l -d 'List all installed and not installed tools'
complete -c termifun -l browse -s b -d 'Browse and install not installed tools'
